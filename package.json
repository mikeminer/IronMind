{
  "name": "ironmind",
  "version": "0.1.0",
  "description": "Native-first CPU/RAM local inference shell with a connected chatbot.",
  "type": "module",
  "bin": {
    "ironmind": "./bin/ironmind.mjs"
  },
  "scripts": {
    "start": "node ./bin/ironmind.mjs serve",
    "doctor": "node ./bin/ironmind.mjs doctor",
    "inspect": "node ./tools/inspect-gguf.mjs",
    "native:build": "cmake -S . -B build && cmake --build build --config Release",
    "test": "node ./tools/test-foundations.mjs",
    "check": "node --check ./bin/ironmind.mjs && node --check ./tools/inspect-gguf.mjs && node ./tools/test-foundations.mjs"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT"
}
